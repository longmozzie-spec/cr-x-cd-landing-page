# SePay sẽ gửi header: Authorization: Apikey <token>
SEPAY_WEBHOOK_TOKEN=doi-thanh-chuoi-bi-mat-ngau-nhien

# --- Admin ---
ADMIN_PASSWORD=doi-thanh-mat-khau-manh
ADMIN_SESSION_SECRET=doi-thanh-chuoi-ngau-nhien-dai-32-ky-tu-tro-len

# --- Google Sheets sync (optional) ---
